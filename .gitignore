# =============================================================================
#  xways-updater — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
#  MSVC / C++ build artifacts (regenerated by build.bat)
# -----------------------------------------------------------------------------
*.obj
*.lib
*.exp
*.res
*.dll
*.pdb
*.ilk
*.idb

# -----------------------------------------------------------------------------
#  Visual Studio / IDE state
# -----------------------------------------------------------------------------
.vs/
.vscode/
.idea/
*.suo
*.user
*.ntvs*
*.njsproj
*.sln.iml

# -----------------------------------------------------------------------------
#  Sidecar config — DPAPI-encrypted user credentials. NEVER commit.
#  Auto-recreated next to the loaded DLL when the user ticks "Remember
#  credentials" in the dialog.
# -----------------------------------------------------------------------------
xways-updater.cfg
*.cfg

# -----------------------------------------------------------------------------
#  Deployment bundle (regenerated by build.bat — drops the DLL, icon, and
#  any cfg next to one another for easy copy into <X-Ways>\xtensions\).
# -----------------------------------------------------------------------------
xtensions/

# -----------------------------------------------------------------------------
#  Backup / archive blobs
# -----------------------------------------------------------------------------
*.7z
*.zip
*.bak

# -----------------------------------------------------------------------------
#  OS metadata
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
desktop.ini
.DS_Store

# -----------------------------------------------------------------------------
#  Claude Code local config
# -----------------------------------------------------------------------------
CLAUDE.md
.claude/
